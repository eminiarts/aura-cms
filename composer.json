{
    "name": "eminiarts/aura-cms",
    "description": "Aura CMS for Laravel",
    "keywords": [
        "Aura",
        "Aura CMS",
        "Laravel Aura",
        "Laravel",
        "Livewire",
        "TALL",
        "TALL Stack",
        "TailwindCSS",
        "AlpineJS",
        "Emini Arts",
        "eminiarts"
    ],
    "homepage": "https://github.com/eminiarts/aura-cms",
    "license": "MIT",
    "authors": [
        {
            "name": "Emini Arts GmbH",
            "email": "support@eminiarts.ch",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "intervention/image": "^3.0",
        "illuminate/support": "^12.0|^13.0",
        "lab404/laravel-impersonate": "^1.7.5",
        "laravel/fortify": "^1.20",
        "laravel/prompts": "^0.3",
        "laravel/sanctum": "^4.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/html-sanitizer": "^7.4.12|^8.0.12"
    },
    "require-dev": {
        "intervention/image-laravel": "^1.0",
        "larastan/larastan": "^2.0|^3.0",
        "laravel/dusk": "^8.0",
        "laravel/framework": "^12.0|^13.0",
        "laravel/pint": "^1.18",
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^1.0|^2.0",
        "spatie/laravel-ray": "^1.32",
        "spatie/ray": "^1.37",
        "spatie/test-time": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Aura\\Base\\": "src",
            "Aura\\Base\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aura\\Base\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "test": "php -d memory_limit=1G vendor/bin/pest --no-coverage --parallel",
        "test-coverage": "php -d memory_limit=1G vendor/bin/pest --coverage --parallel --min=80",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lab404\\Impersonate\\ImpersonateServiceProvider",
                "Aura\\Base\\Providers\\AuthServiceProvider",
                "Aura\\Base\\Providers\\AppServiceProvider",
                "Aura\\Base\\AuraServiceProvider"
            ],
            "aliases": {
                "Aura": "Aura\\Base\\Facades\\Aura"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
